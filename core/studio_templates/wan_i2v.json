{
  "_meta": {
    "name": "WAN I2V — DELULUREEL v1",
    "description": "WAN 2.2 I2V 14B fp8 scaled — 480x832 default (9:16 portrait). Width/height overridable via studio_workflows.substitute() on node '10'. VHS_VideoCombine output (gifs key) compatible with handler.py _collect_outputs.",
    "model_unet": "wan2.2_i2v_high_noise_14B_fp8_scaled.safetensors",
    "format": "comfyui_api",
    "created": "2026-06-09",
    "override_dims": "substitute({'10': {'width': W, 'height': H}}) — 9:16=480x832  16:9=832x480  1:1=640x640"
  },
  "1":  {"class_type": "UNETLoader",       "inputs": {"unet_name": "wan2.2_i2v_high_noise_14B_fp8_scaled.safetensors", "weight_dtype": "fp8_e4m3fn"}},
  "2":  {"class_type": "CLIPLoader",       "inputs": {"clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors", "type": "wan", "device": "default"}},
  "3":  {"class_type": "VAELoader",        "inputs": {"vae_name": "wan_2.1_vae.safetensors"}},
  "4":  {"class_type": "CLIPVisionLoader", "inputs": {"clip_name": "clip_vision_h.safetensors"}},
  "5":  {"class_type": "LoadImage",        "inputs": {"image": "input_photo.png", "upload": "image"}},
  "6":  {"class_type": "CLIPTextEncode",   "inputs": {"text": "cinematic video, smooth motion, high quality", "clip": ["2", 0]}},
  "7":  {"class_type": "CLIPTextEncode",   "inputs": {"text": "blurry, ugly, deformed, low quality, static, watermark", "clip": ["2", 0]}},
  "8":  {"class_type": "CLIPVisionEncode", "inputs": {"clip_vision": ["4", 0], "image": ["5", 0], "crop": "none"}},
  "9":  {"class_type": "ModelSamplingSD3", "inputs": {"model": ["1", 0], "shift": 8.0}},
  "10": {
    "class_type": "WanImageToVideo",
    "inputs": {
      "positive":           ["6", 0],
      "negative":           ["7", 0],
      "vae":                ["3", 0],
      "clip_vision_output": ["8", 0],
      "start_image":        ["5", 0],
      "width":  480,
      "height": 832,
      "length": 33,
      "batch_size": 1
    }
  },
  "11": {
    "class_type": "KSampler",
    "inputs": {
      "model":        ["9",  0],
      "positive":     ["10", 0],
      "negative":     ["10", 1],
      "latent_image": ["10", 2],
      "seed":         42,
      "steps":        20,
      "cfg":          6.0,
      "sampler_name": "euler",
      "scheduler":    "simple",
      "denoise":      1.0
    }
  },
  "12": {"class_type": "VAEDecode", "inputs": {"samples": ["11", 0], "vae": ["3", 0]}},
  "13": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images":          ["12", 0],
      "frame_rate":      24,
      "loop_count":      0,
      "filename_prefix": "DELULUREEL/reel",
      "format":          "video/h264-mp4",
      "pingpong":        false,
      "save_output":     true
    }
  }
}
