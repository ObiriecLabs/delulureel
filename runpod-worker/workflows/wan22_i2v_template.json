{
  "__TEMPLATE_META__": {
    "version": "1.0",
    "model": "WAN 2.2 I2V 14B fp8 + LightX2V 4-step LoRA",
    "pipeline": "HIGH(steps 0-3) → LOW(steps 3-6) → decode → mp4",
    "runtime_substitutions": {
      "__IMAGE_FILENAME__": "filename saved to /comfyui/input/ by handler (e.g. photo.jpg)",
      "__POSITIVE_PROMPT__": "scene description from Claude scene_director",
      "__NEGATIVE_PROMPT__": "standard negative prompt string",
      "__WIDTH__":  "target video width  — 480 (9:16) | 832 (16:9) | 608 (1:1)",
      "__HEIGHT__": "target video height — 832 (9:16) | 480 (16:9) | 608 (1:1)",
      "__NUM_FRAMES__": "total frames: 81=5s | 121=7.5s | 161=10s at 16fps (must be 4k+1)",
      "__SEED__": "integer seed for reproducibility"
    },
    "models_required_on_volume": [
      "diffusion_models/wan2.2_i2v_high_noise_14B_fp8_scaled.safetensors",
      "diffusion_models/wan2.2_i2v_low_noise_14B_fp8_scaled.safetensors",
      "text_encoders/umt5_xxl_fp8_e4m3fn_scaled.safetensors",
      "vae/wan2.2_vae.safetensors",
      "loras/wan2.2_i2v_lightx2v_4steps_lora_v1_high_noise.safetensors",
      "loras/wan2.2_i2v_lightx2v_4steps_lora_v1_low_noise.safetensors"
    ],
    "notes": [
      "attention_mode=sdpa: sageattention non installata nel worker, sdpa è PyTorch nativo",
      "No block swap: H200/A100/RTX6000Ada hanno VRAM sufficiente per 14B fp8 (14GB/modello)",
      "LoRA HIGH strength=3 / LOW strength=1 — valori dall'esempio ufficiale WanVideoWrapper",
      "CFG=1.0 costante — LightX2V è un modello distillato, non richiede CFG alto",
      "WAN 2.2 split-step: HIGH model fa prima metà (rumore alto), LOW fa seconda metà"
    ]
  },

  "t5_loader": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "inputs": {
      "model_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
      "precision": "bf16",
      "load_device": "offload_device",
      "quantization": "disabled"
    }
  },

  "text_encode": {
    "class_type": "WanVideoTextEncode",
    "inputs": {
      "positive_prompt": "__POSITIVE_PROMPT__",
      "negative_prompt": "__NEGATIVE_PROMPT__",
      "t5": ["t5_loader", 0],
      "force_offload": true,
      "device": "gpu"
    }
  },

  "vae_loader": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "wan2.2_vae.safetensors",
      "precision": "bf16"
    }
  },

  "lora_high": {
    "class_type": "WanVideoLoraSelect",
    "inputs": {
      "lora": "wan2.2_i2v_lightx2v_4steps_lora_v1_high_noise.safetensors",
      "strength": 3.0
    }
  },

  "lora_low": {
    "class_type": "WanVideoLoraSelect",
    "inputs": {
      "lora": "wan2.2_i2v_lightx2v_4steps_lora_v1_low_noise.safetensors",
      "strength": 1.0,
      "prev_lora": null
    }
  },

  "model_high": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "wan2.2_i2v_high_noise_14B_fp8_scaled.safetensors",
      "base_precision": "fp16_fast",
      "quantization": "fp8_e4m3fn_scaled",
      "load_device": "offload_device",
      "attention_mode": "sdpa",
      "lora": ["lora_high", 0]
    }
  },

  "model_low": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "wan2.2_i2v_low_noise_14B_fp8_scaled.safetensors",
      "base_precision": "fp16_fast",
      "quantization": "fp8_e4m3fn_scaled",
      "load_device": "offload_device",
      "attention_mode": "sdpa",
      "lora": ["lora_low", 0]
    }
  },

  "load_image": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "__IMAGE_FILENAME__",
      "upload": "image"
    }
  },

  "image_encode": {
    "class_type": "WanVideoImageToVideoEncode",
    "inputs": {
      "vae": ["vae_loader", 0],
      "start_image": ["load_image", 0],
      "width": "__WIDTH__",
      "height": "__HEIGHT__",
      "num_frames": "__NUM_FRAMES__",
      "noise_aug_strength": 0.0,
      "start_latent_strength": 1.0,
      "end_latent_strength": 1.0,
      "force_offload": true
    }
  },

  "sampler_high": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["model_high", 0],
      "image_embeds": ["image_encode", 0],
      "text_embeds": ["text_encode", 0],
      "steps": 6,
      "cfg": 1.0,
      "shift": 8.0,
      "seed": "__SEED__",
      "force_offload": true,
      "scheduler": "dpm++_sde",
      "riflex_freq_index": 0,
      "start_step": 0,
      "end_step": 3
    }
  },

  "sampler_low": {
    "class_type": "WanVideoSampler",
    "inputs": {
      "model": ["model_low", 0],
      "image_embeds": ["image_encode", 0],
      "text_embeds": ["text_encode", 0],
      "samples": ["sampler_high", 0],
      "steps": 6,
      "cfg": 1.0,
      "shift": 8.0,
      "seed": "__SEED__",
      "force_offload": true,
      "scheduler": "dpm++_sde",
      "riflex_freq_index": 0,
      "start_step": 3,
      "end_step": -1
    }
  },

  "decode": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["vae_loader", 0],
      "samples": ["sampler_low", 0],
      "enable_vae_tiling": false,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    }
  },

  "combine_video": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["decode", 0],
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "delulureel",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 19,
      "save_metadata": false,
      "trim_to_audio": false,
      "pingpong": false,
      "save_output": true
    }
  }
}
